CICADA_MEMORY_PATH=/path/to/cicada/memory

# Embedding backend for the LEANN semantic indexes.
#   openai  -> text-embedding-3-small (fast, needs OPENAI_API_KEY, ~free at this
#              scale, 1536-dim)
#   local   -> sentence-transformers/all-MiniLM-L6-v2 (offline, no key, heavier
#              install ~250MB incl. torch, slower on CPU, 384-dim so slightly
#              coarser recall). Needs the optional extra:
#              uv sync --extra local --directory api
# If left as openai but no OPENAI_API_KEY is set, Cicada auto-degrades to local
# so a key-less install still gets semantic search.
CICADA_EMBEDDING_MODE=openai
# Override the OpenAI embedding model if desired (only used in openai mode).
CICADA_EMBEDDING_MODEL=text-embedding-3-small

# Model to use for Sleep cycle (litellm format: provider/model)
# Examples: gpt-5.4-mini, openai/gpt-4o-mini, anthropic/claude-sonnet-4-20250514, gemini/gemini-2.0-flash
CICADA_LITELLM_MODEL=gpt-5.4-mini

# Optional dedicated model for Stage 2 same/different/unsure disambiguation.
# Defaults to gpt-5.4-nano if omitted.
CICADA_LITELLM_DISAMBIGUATION_MODEL=gpt-5.4-nano

# LiteLLM reads these standard env vars automatically — set whichever you use
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-key
